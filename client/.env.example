# Default conversation server used when localStorage has no saved URL.
# For a LAN setup (e.g. MacBook -> inference PC), set this to the inference PC.
VITE_GIC_DEFAULT_BASE_URL=http://192.168.0.10:8000

# Optional. Change this when you want separate saved connection URLs per profile.
# VITE_GIC_BASE_URL_STORAGE_KEY=gemma4-irodori-chat.base-url
